[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[branch "react-ver-4"]
	vscode-merge-base = origin/react-ver
[branch "main"]
	vscode-merge-base = origin/react-ver-4
	remote = origin
	merge = refs/heads/main
[remote "origin"]
	url = https://github.com/alxxrzfyr/proof-web.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "need_info"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/need_info
